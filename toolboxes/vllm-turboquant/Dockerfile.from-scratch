# vLLM + TurboQuant — Full Build from Scratch for AMD Strix Halo (gfx1151)
# Based on kyuz0/amd-strix-halo-vllm-toolboxes Dockerfile
# with TurboQuant KV cache compression baked in.
#
# Build (long — 2-4h):
#   podman build --no-cache -t vllm-turboquant-gfx1151:from-scratch \
#     -f Dockerfile.from-scratch .
#
# This is the "Plan B" standalone build that doesn't depend on kyuz0's pre-built image.

FROM registry.fedoraproject.org/fedora:43

LABEL maintainer="Rafale83"
LABEL description="vLLM + TurboQuant from scratch for Strix Halo gfx1151"

# ── 1. System deps ──────────────────────────────────────────────────────
RUN dnf install -y \
    cmake ninja-build gcc gcc-c++ git wget curl unzip \
    python3.12 python3.12-devel python3-pip \
    gperftools-libs numactl-libs pciutils \
    && dnf clean all

# ── 2. TheRock ROCm SDK (nightly, gfx1151) ─────────────────────────────
ARG ROCM_MAJOR_VER=7
ARG GFX=gfx1151
WORKDIR /tmp

RUN TARBALL_URL=$(curl -s "https://therock-nightly-tarball.s3.amazonaws.com/?list-type=2&prefix=therock-dist-linux-${GFX}-${ROCM_MAJOR_VER}" \
    | grep -oP '<Key>[^<]+</Key>' | sed 's/<[^>]*>//g' | sort | tail -1) && \
    echo "Downloading: ${TARBALL_URL}" && \
    wget -q "https://therock-nightly-tarball.s3.amazonaws.com/${TARBALL_URL}" -O rocm.tar.gz && \
    mkdir -p /opt/rocm && \
    tar xzf rocm.tar.gz -C /opt/rocm --strip-components=1 && \
    rm rocm.tar.gz

ENV ROCM_HOME=/opt/rocm
ENV HIP_PATH=/opt/rocm
ENV PATH=/opt/rocm/bin:/opt/rocm/llvm/bin:$PATH
ENV LD_LIBRARY_PATH=/opt/rocm/lib:/opt/rocm/lib64:$LD_LIBRARY_PATH
ENV HSA_PATH=/opt/rocm

# ── 3. Python venv ──────────────────────────────────────────────────────
RUN /usr/bin/python3.12 -m venv /opt/venv
ENV VIRTUAL_ENV=/opt/venv
ENV PATH=/opt/venv/bin:$PATH
ENV PIP_NO_CACHE_DIR=1
RUN printf 'source /opt/venv/bin/activate\n' > /etc/profile.d/venv.sh
RUN python -m pip install --upgrade pip wheel packaging "setuptools<80.0.0"

# ── 4. PyTorch (TheRock nightly for gfx1151) ───────────────────────────
RUN python -m pip install \
    --index-url https://rocm.nightlies.amd.com/v2-staging/gfx1151/ \
    --pre torch torchaudio torchvision && \
    sed -i 's/json.dumps(config_dict, sort_keys=True)/json.dumps(config_dict, sort_keys=True, default=str)/g' \
    /opt/venv/lib64/python3.12/site-packages/torch/_dynamo/utils.py

WORKDIR /opt

# ── 5. Flash Attention (ROCm fork) ─────────────────────────────────────
ENV FLASH_ATTENTION_TRITON_AMD_ENABLE="TRUE"
RUN git clone https://github.com/ROCm/flash-attention.git && \
    cd flash-attention && git checkout main_perf && \
    python setup.py install && \
    cd /opt && rm -rf flash-attention

# ── 6. vLLM (patched for gfx1151) ──────────────────────────────────────
RUN git clone https://github.com/vllm-project/vllm.git /opt/vllm
WORKDIR /opt/vllm

COPY patch_strix.py /opt/vllm/patch_strix.py
RUN python patch_strix.py && \
    sed -i 's/gfx1200;gfx1201/gfx1151/' CMakeLists.txt

RUN python -m pip install --upgrade cmake ninja packaging wheel numpy \
    "setuptools-scm>=8" "setuptools<80.0.0" scikit-build-core pybind11

ENV VLLM_TARGET_DEVICE="rocm"
ENV PYTORCH_ROCM_ARCH="gfx1151"
ENV HIP_ARCHITECTURES="gfx1151"
ENV AMDGPU_TARGETS="gfx1151"
ENV MAX_JOBS="4"
ENV CC="/opt/rocm/llvm/bin/clang"
ENV CXX="/opt/rocm/llvm/bin/clang++"

RUN export HIP_DEVICE_LIB_PATH=$(find /opt/rocm -type d -name bitcode -print -quit) && \
    export CMAKE_ARGS="-DROCM_PATH=/opt/rocm -DHIP_PATH=/opt/rocm -DAMDGPU_TARGETS=gfx1151 -DHIP_ARCHITECTURES=gfx1151" && \
    python -m pip wheel --no-build-isolation --no-deps -w /tmp/dist -v . && \
    python -m pip install /tmp/dist/*.whl && \
    rm -rf /tmp/dist

RUN python -m pip install ray

# ── 7. bitsandbytes (ROCm, gfx1151) ────────────────────────────────────
WORKDIR /opt
RUN git clone -b rocm_enabled_multi_backend https://github.com/ROCm/bitsandbytes.git
WORKDIR /opt/bitsandbytes
ENV HIP_PLATFORM="amd"
ENV CMAKE_PREFIX_PATH="/opt/rocm"
RUN cmake -S . \
    -DGPU_TARGETS="gfx1151" \
    -DBNB_ROCM_ARCH="gfx1151" \
    -DCOMPUTE_BACKEND=hip \
    -DCMAKE_HIP_COMPILER=/opt/rocm/llvm/bin/clang++ \
    -DCMAKE_CXX_COMPILER=/opt/rocm/llvm/bin/clang++ && \
    make -j$(nproc) && \
    python -m pip install --no-build-isolation --no-deps .

# ── 8. TurboQuant KV cache compression ─────────────────────────────────
RUN python -m pip install "turboquant-vllm[vllm]"
ENV TQ4_K_BITS=4
ENV TQ4_V_BITS=4

# ── 9. Transformers upgrade ────────────────────────────────────────────
RUN python -m pip install transformers==5.3.0

# ── 10. Cleanup ────────────────────────────────────────────────────────
WORKDIR /opt
RUN chmod -R a+rwX /opt && \
    find /opt/venv -type f -name "*.so" -exec strip -s {} + 2>/dev/null || true && \
    find /opt/venv -type d -name "__pycache__" -prune -exec rm -rf {} + && \
    rm -rf /root/.cache/pip /opt/bitsandbytes /opt/vllm/.git && \
    dnf clean all && rm -rf /var/cache/dnf/*

# ── 11. Scripts & entrypoint ───────────────────────────────────────────
COPY start-vllm-tq /opt/start-vllm-tq
RUN chmod +x /opt/start-vllm-tq && \
    ln -sf /opt/start-vllm-tq /usr/local/bin/start-vllm-tq

RUN printf 'ulimit -S -c 0\n' > /etc/profile.d/90-nocoredump.sh && chmod 0644 /etc/profile.d/90-nocoredump.sh
RUN printf '\necho "═══════════════════════════════════════════════"\n\
echo " vLLM + TurboQuant — Strix Halo (gfx1151)"\n\
echo " KV cache: ${TQ4_K_BITS}/${TQ4_V_BITS}-bit compression"\n\
echo " start-vllm-tq --model <model>"\n\
echo "═══════════════════════════════════════════════"\n' \
> /etc/profile.d/99-toolbox-banner.sh && chmod 0644 /etc/profile.d/99-toolbox-banner.sh

# ROCm env for Triton
RUN printf 'export ROCM_HOME=/opt/rocm\n\
export HIP_PATH=/opt/rocm\n\
export LD_LIBRARY_PATH=/opt/rocm/lib:/opt/rocm/lib64:$LD_LIBRARY_PATH\n\
export PATH=/opt/rocm/bin:$PATH\n\
export ROCBLAS_USE_HIPBLASLT=1\n\
export TORCH_ROCM_AOTRITON_ENABLE_EXPERIMENTAL=1\n\
export FLASH_ATTENTION_TRITON_AMD_ENABLE=TRUE\n\
export HIP_FORCE_DEV_KERNARG=1\n\
export VLLM_ROCM_USE_AITER=0\n\
export VLLM_ROCM_USE_AITER_MOE=0\n\
export VLLM_USE_TRITON_AWQ=1\n\
export VLLM_USE_MMAP=0\n\
export LD_PRELOAD=/usr/lib64/libtcmalloc_minimal.so.4\n' \
> /etc/profile.d/01-rocm-env-for-triton.sh && chmod 0644 /etc/profile.d/01-rocm-env-for-triton.sh

CMD ["/bin/bash"]
